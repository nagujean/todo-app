# 환경 변수 템플릿
#
# 로컬 개발을 위해 이 파일을 .env.local로 복사하세요
# .env.local은 버전 제어에 커밋하지 마세요

# ============================================================================
# Firebase 설정 (필수)
# ============================================================================
# Firebase 콘솔 프로젝트 설정에서 가져오세요
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ============================================================================
# Sentry 설정 (선택사항 - 프로덕션 권장)
# ============================================================================
# Sentry 프로젝트 설정에서 DSN을 가져오세요: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# 환경 태그 (development | staging | production)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development

# ============================================================================
# Vercel 설정 (배포용)
# ============================================================================
# Vercel 프로젝트 설정에서 가져오세요
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
# Git 커밋 SHA (CI/CD에서 자동 설정)
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# ============================================================================
# Slack 알림 (선택사항)
# ============================================================================
# 웹훅 생성: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ============================================================================
# 노드 환경
# ============================================================================
# development | production | test
NODE_ENV=development
